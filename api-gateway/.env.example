# Environment template (no secrets - safe to commit)

APP_NAME=api-gateway
APP_HOST=0.0.0.0
APP_PORT=8000

# Timeout used for all upstream requests and downstream health checks.
REQUEST_TIMEOUT_SECONDS=10

# Downstream service base URLs
USER_SERVICE_URL=http://127.0.0.1:8001
PRODUCT_SERVICE_URL=http://127.0.0.1:8002
ORDER_SERVICE_URL=http://127.0.0.1:8003
PAYMENT_SERVICE_URL=http://127.0.0.1:8004
CART_SERVICE_URL=http://127.0.0.1:8005
REVIEW_SERVICE_URL=http://127.0.0.1:8006
